{
  "ConnectionStrings": {
    "Default": "Data Source=flowengine.db;Mode=ReadWriteCreate;Cache=Shared"
  },
  "Plugins": {
    "Path": "../../plugins"
  },
  "Expression": {
    "EnvironmentWhitelist": []
  },
  "Storage": {
    "Type": "LocalFileSystem",
    "Path": "./storage"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
