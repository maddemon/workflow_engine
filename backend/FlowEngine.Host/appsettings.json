{
  "Database": {
    "Provider": "sqlite"
  },
  "ConnectionStrings": {
    "Default": "Data Source=App_Data/flowengine.db;Mode=ReadWriteCreate;Cache=Shared"
  },
  "Plugins": {
    "Path": "../../plugins"
  },
  "Expression": {
    "EnvironmentWhitelist": []
  },
  "Storage": {
    "Type": "LocalFileSystem",
    "Path": "./storage"
  },
  "Audit": {
    "LogPath": "./storage/audit"
  },
  "Jwt": {
    "Secret": "FlowEngine-Dev-Secret-Key-Change-In-Production-Must-Be-At-Least-32-Bytes!",
    "Issuer": "FlowEngine",
    "Audience": "FlowEngine",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
